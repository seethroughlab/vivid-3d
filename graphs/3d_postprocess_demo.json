{
  "nodes": {
    "sphere":  { "type": "Shape3D", "params": { "shape": 1, "pos_x": -2.0, "r": 0.9, "g": 0.2, "b": 0.2 } },
    "cube":    { "type": "Shape3D", "params": { "shape": 0, "pos_x": 2.0, "pos_z": -1.0, "r": 0.2, "g": 0.7, "b": 0.9 } },
    "torus":   { "type": "Shape3D", "params": { "shape": 2, "pos_x": 0.0, "pos_z": 2.0, "r": 0.3, "g": 0.9, "b": 0.3 } },
    "light":   { "type": "Light3D", "params": { "type": 0, "intensity": 1.2 } },
    "merge":   { "type": "SceneMerge" },
    "render":  { "type": "Render3D", "params": { "cam_y": 3.0, "cam_z": 7.0 } },
    "ssao":    { "type": "SSAO3D", "params": { "radius": 0.5, "intensity": 1.5 } },
    "dof":     { "type": "DepthOfField3D", "params": { "focus_distance": 5.0, "aperture": 0.8 } },
    "vout":    { "type": "video_out" }
  },
  "connections": [
    { "from": "sphere/scene",    "to": "merge/scene_a" },
    { "from": "cube/scene",      "to": "merge/scene_b" },
    { "from": "torus/scene",     "to": "merge/scene_c" },
    { "from": "light/scene",     "to": "merge/scene_d" },
    { "from": "merge/scene",     "to": "render/scene" },
    { "from": "render/texture",  "to": "ssao/color" },
    { "from": "render/depth",    "to": "ssao/depth" },
    { "from": "ssao/texture",    "to": "dof/color" },
    { "from": "render/depth",    "to": "dof/depth" },
    { "from": "dof/texture",     "to": "vout/input" }
  ]
}
