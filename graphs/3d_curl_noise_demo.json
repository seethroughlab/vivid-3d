{
  "nodes": {
    "particles": {
      "type": "Particles3D",
      "params": {
        "count": 50000,
        "emission_rate": 10000,
        "lifetime": 8.0,
        "speed": 1.0,
        "gravity": 0.0,
        "spread": 360.0,
        "size": 0.03,
        "drag": 1.5,
        "curl_strength": 3.0,
        "noise_scale": 0.8,
        "noise_speed": 0.3,
        "noise_octaves": 2,
        "shape": 1,
        "elongation": 5,
        "unlit": 0,
        "emission": 0.8,
        "r": 1.0,
        "g": 0.9,
        "b": 0.7,
        "a": 0.8
      }
    },
    "light_red":   { "type": "Light3D", "params": { "type": 1, "r": 1.0, "g": 0.0, "b": 0.0, "intensity": 5.0, "pos_x": -10.0, "pos_y": 0.0, "pos_z": 3.0, "radius": 40.0 } },
    "light_blue":  { "type": "Light3D", "params": { "type": 1, "r": 0.0, "g": 0.18, "b": 1.0, "intensity": 5.0, "pos_x": 5.0, "pos_y": -4.0, "pos_z": 10.0, "radius": 40.0 } },
    "light_white": { "type": "Light3D", "params": { "type": 1, "r": 1.0, "g": 1.0, "b": 1.0, "intensity": 2.0, "pos_x": 0.0, "pos_y": 10.0, "pos_z": -10.0, "radius": 40.0 } },
    "lfo_r": { "type": "LFO", "params": { "frequency": 0.3, "amplitude": 4.0, "offset": 3.0 } },
    "lfo_b": { "type": "LFO", "params": { "frequency": 0.5, "amplitude": 4.0, "offset": 3.0 } },
    "lfo_w": { "type": "LFO", "params": { "frequency": 0.2, "amplitude": 1.0, "offset": 1.5 } },
    "merge":  { "type": "SceneMerge" },
    "render": { "type": "Render3D", "params": { "cam_z": 20.0, "fov": 41.0, "bg_r": 0.0, "bg_g": 0.0, "bg_b": 0.0, "shadow_enabled": 1.0 } },
    "dof":    { "type": "DepthOfField3D", "params": { "focus_distance": 8.0, "aperture": 0.5, "max_blur": 8.0 } },
    "levels": { "type": "Levels", "params": { "brightness": 0.3, "contrast": 1.2 } },
    "bloom":  { "type": "Bloom", "params": { "threshold": 0.15, "intensity": 1.5, "passes": 4 } },
    "vout":   { "type": "video_out" }
  },
  "connections": [
    { "from": "particles/scene",   "to": "merge/scene_a" },
    { "from": "light_red/scene",   "to": "merge/scene_b" },
    { "from": "light_blue/scene",  "to": "merge/scene_c" },
    { "from": "light_white/scene", "to": "merge/scene_d" },
    { "from": "merge/scene",       "to": "render/scene" },
    { "from": "render/texture",    "to": "dof/color" },
    { "from": "render/depth",      "to": "dof/depth" },
    { "from": "dof/texture",       "to": "levels/input" },
    { "from": "levels/texture",    "to": "bloom/input" },
    { "from": "bloom/texture",     "to": "vout/input" },
    { "from": "lfo_r/value",       "to": "light_red/intensity" },
    { "from": "lfo_b/value",       "to": "light_blue/intensity" },
    { "from": "lfo_w/value",       "to": "light_white/intensity" }
  ]
}
